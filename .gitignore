Thumbs.db
desktop.ini
.DS_Store
*.swp

# staged asset downloads (tools/fetch_assets.sh)
assets/_staging/
__pycache__/

# Local non-destructive rig/mesh diagnostic output
/audit/

# local API keys — never committed
.secrets/

# Kokoro TTS model + voice packs (downloaded per make_voices.py setup docs)
tools/kokoro/
*.blend1
