{
	"permissions": {
		"deny": [
			"Read(./.secrets/**)",
			"Read(**/*.keystore)",
			"Read(**/*.jks)",
			"Read(**/*.p12)",
			"Bash(git push origin master)",
			"Bash(git push origin master:*)",
			"Bash(git push origin HEAD:master)",
			"Bash(git push -f:*)",
			"Bash(git push --force :*)",
			"Bash(git push --force origin:*)"
		]
	}
}
